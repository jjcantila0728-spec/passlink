# PassLink Telegram bot configuration.
# Copy to .env for local dev, or set these as environment variables on Vercel.

# From @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs that are always authorized and can manage other users.
# Send /whoami to the bot to find a chat ID.
TELEGRAM_ADMIN_CHAT_IDS=

# Optional shared secret verifying webhook calls really come from Telegram.
# If set, pass the same value when registering the webhook (set-webhook does this automatically).
TELEGRAM_WEBHOOK_SECRET=

# Optional: pre-approved group chat IDs (comma separated, negative numbers).
# Usually you don't set this — add the bot to a group and run /approvegroup there.
# Run /whoami inside a group to read its numeric chat ID.
TELEGRAM_APPROVED_GROUP_IDS=

# Optional: warnings before a member is auto-banned in a group (default 3).
TELEGRAM_WARN_LIMIT=

# Optional: countdown seconds shown before revealing a bypassed link (default 5).
TELEGRAM_COUNTDOWN_SECONDS=

# Durable storage (STRONGLY recommended on Vercel). Without one of these, the bot
# falls back to /tmp, which Vercel wipes on cold start — so group approvals and
# the allowlist are lost after a few hours.
#
# Option A (preferred): Supabase Postgres. Create a `passlink_kv` table and paste
# the project URL + the SECRET service_role key (Project Settings → API). The
# service_role key bypasses RLS and must stay server-side only — never expose it.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: override the table name (defaults to passlink_kv).
# SUPABASE_KV_TABLE=passlink_kv
#
# Option B: Vercel KV / Upstash. Connecting Vercel KV (Storage tab) injects these
# two automatically; you don't normally set them by hand.
KV_REST_API_URL=
KV_REST_API_TOKEN=
