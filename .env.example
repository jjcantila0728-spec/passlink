# PassLink Telegram bot configuration.
# Copy to .env for local dev, or set these as environment variables on Vercel.

# From @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs that are always authorized and can manage other users.
# Send /whoami to the bot to find a chat ID.
TELEGRAM_ADMIN_CHAT_IDS=

# Optional shared secret verifying webhook calls really come from Telegram.
# If set, pass the same value when registering the webhook (set-webhook does this automatically).
TELEGRAM_WEBHOOK_SECRET=
